# Copy to .env.local or load in shell before migrate:anon-usage

# Required for backend and for `pnpm migrate:anon-usage`
DATABASE_URL=postgresql://awa_app:YOUR_PASSWORD@127.0.0.1:5432/awa_db

# Cloud Run / local: same value as Next.js (anon IP rate limit hash)
AURA_IP_HASH_SALT=change-me-use-long-random-string

# Optional: Cloud SQL socket (host in DATABASE_URL ignored when set)
# CLOUD_SQL_CONNECTION_NAME=project:region:instance

# GCS bucket for images
# GCS_IMAGES_BUCKET=your-bucket

# Server-to-server auth (Next Stripe webhook → /api/billing/*, debug/cron in production)
# GCP_BILLING_INTERNAL_SECRET=long-random-string
# CRON_SECRET=long-random-string
# MIGRATE_SECRET=long-random-string
