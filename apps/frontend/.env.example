# Copy to .env.local

# Backend API (required for anon limits via Cloud SQL instead of in-memory fallback)
NEXT_PUBLIC_GCP_API_BASE_URL=https://your-backend.run.app

# Server-side (Next API routes /api/credits/*). Must match backend-gcp AURA_IP_HASH_SALT.
AURA_IP_HASH_SALT=change-me-use-long-random-string

# Optional: force in-process anon limits (no Cloud SQL tables needed)
# AWA_ANON_LIMITS_MEMORY_ONLY=true
