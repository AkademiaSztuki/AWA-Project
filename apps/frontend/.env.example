# Copy to .env.local

# Backend API (required for anon limits via Cloud SQL instead of in-memory fallback)
NEXT_PUBLIC_GCP_API_BASE_URL=https://your-backend.run.app

# Server-side (Next API routes /api/credits/*). Must match backend-gcp AURA_IP_HASH_SALT.
AURA_IP_HASH_SALT=change-me-use-long-random-string

# Optional: force in-process anon limits (no Cloud SQL tables needed)
# IDA_ANON_LIMITS_MEMORY_ONLY=true
# (legacy alias still supported: AWA_ANON_LIMITS_MEMORY_ONLY=true)

# Google sign-in (GIS + backend link-auth)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Cursor/Electron dev automatically uses implicit token redirect (no client secret needed) because GIS popup may be blank.
# Optional: always use PKCE code redirect (requires server-side GOOGLE_CLIENT_SECRET).
# NEXT_PUBLIC_GOOGLE_OAUTH_USE_PKCE_REDIRECT=1
# PKCE redirect return URL — MUST match Google Cloud → OAuth 2.0 Client → Authorized redirect URIs (exact copy, no typo)
# Only needed when NEXT_PUBLIC_GOOGLE_OAUTH_USE_PKCE_REDIRECT=1 or when popup_failed_to_open fallback is used.
# The default is http://localhost:3000/auth/callback, matching docs/migration/auth-google-native.md
# NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
# Required for Google OAuth "Web application" clients when using PKCE redirect in Cursor.
# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID → Client secret
# Keep server-side only. Do not prefix with NEXT_PUBLIC_.
# GOOGLE_CLIENT_SECRET=

# Contact form (/api/contact) — server-side only
# RESEND_API_KEY=re_...
# RESEND_FROM=IDA <jakub@project-ida.com>
