# Skopiuj ten plik jako setup.env i uzupełnij wartości.
# setup.env nie jest commitowany do gita (.gitignore).

# Id projektu Google Cloud (np. awa-badania-2025)
PROJECT_ID=twoj-projekt-id

# Id konta rozliczeniowego z kredytami EDU (Billing → Manage billing accounts)
BILLING_ACCOUNT=01234A-BCDEF5-678901

# Region (europe-west4 = Holandia, dobre opóźnienia do Polski)
REGION=europe-west4

# Silne hasło do użytkownika bazy PostgreSQL (awa_app)
HASLO_BAZY=TwojeBardzoSilneHaslo123!

# Connection name Cloud SQL (do Cloud SQL Proxy / IAM) – SQL → instancja → "Connection name"
# Format: PROJECT_ID:REGION:INSTANCE_NAME (np. project-a2c75857-73b0-4982-acf:europe-west4:awa-research-sql)
CLOUD_SQL_CONNECTION_NAME=twoj-projekt:europe-west4:awa-research-sql

# Nazwa instancji Cloud SQL (do skryptu infra/gcp/scripts/cloud-sql-connect.ps1)
# GCP_SQL_INSTANCE_NAME=awa-research-sql

# Opcjonalnie: service account Cloud SQL (używany przy połączeniu IAM z Cloud Run)
# Znajdziesz w: SQL → instancja → Connections → "Cloud SQL IAM service account"
# GCP_SA_CLOUD_SQL=p986280192250-327ufi@gcp-sa-cloud-sql.iam.gserviceaccount.com
