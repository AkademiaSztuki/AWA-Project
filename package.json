{
  "name": "aura-research-monorepo",
  "version": "1.0.0",
  "description": "AI Interior Design Dialogue - Research Application",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:frontend": "pnpm --filter @aura/frontend build",
    "build:backend-gcp": "pnpm --filter @aura/backend-gcp build",
    "build:research-stack": "pnpm run build:backend-gcp && pnpm run build:frontend",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:backend-gcp": "pnpm --filter @aura/backend-gcp dev",
    "deploy:frontend": "cd apps/frontend && vercel deploy",
    "vercel:link:frontend": "cd apps/frontend && vercel link --project awa-project-frontend-fhka --yes --scope pali89s-projects"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^1.13.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Aura Research Team - Akademia Sztuk Pięknych",
  "license": "MIT",
  "dependencies": {
    "@vercel/speed-insights": "^1.2.0"
  }
}